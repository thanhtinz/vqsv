# Auto detect text files and perform LF normalization
* text=auto
# Gradle wrapper: shell script must stay LF, Windows batch must stay CRLF
gradlew text eol=lf
*.bat text eol=crlf
*.kt text eol=lf
*.java text eol=lf
*.dart text eol=lf
*.xml text eol=lf
*.kts text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.properties text eol=lf
*.gradle text eol=lf
*.html text eol=lf
*.css text eol=lf
# Binary files
*.mid binary
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.wav binary
*.mp3 binary
