# ============================================================
# VQSV Production Environment — copy to `.env` and fill in.
#   cp .env.example .env && ./scripts/gen-secrets.sh
# NEVER commit the real .env file (it is git-ignored).
# ============================================================

# --- Database (PostgreSQL) ---
POSTGRES_DB=vqsv
POSTGRES_USER=vqsv
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# --- Server secrets ---
# JWT secret MUST be at least 32 bytes. Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_run_openssl_rand_base64_48
JWT_EXPIRATION_MS=86400000

# --- Public domain for HTTPS (used by Caddy reverse proxy) ---
# Point this domain's A record at your VPS IP first.
PUBLIC_DOMAIN=play.example.com
# Email for Let's Encrypt certificate notices
ACME_EMAIL=admin@example.com

# --- Ports exposed on the host ---
# 80/443 served by Caddy (HTTP API + WebSocket, auto-HTTPS).
# 9090 is the raw J2ME binary TCP gateway (must be exposed directly).
TCP_PORT=9090

# --- Payment gateway: VNPAY (optional; leave disabled to use manual top-up) ---
# Get TMN code + hash secret from your VNPAY merchant account.
VNPAY_ENABLED=false
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
# Sandbox by default; switch to the live pay URL when going live.
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# Where VNPAY redirects the buyer back to (must be your public domain):
# VNPAY_RETURN_URL=https://play.example.com/api/web/public/topup/vnpay/return

# --- Tuning (optional) ---
DB_POOL_MAX=20
TOMCAT_MAX_THREADS=200
