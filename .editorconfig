# EditorConfig — consistent style across editors (https://editorconfig.org)
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Kotlin / Java (server + LibGDX clients)
[*.{kt,kts,java}]
indent_size = 4
max_line_length = 120

# Web / admin (TypeScript, JS, JSON, CSS)
[*.{ts,tsx,js,jsx,json,css,scss}]
indent_size = 2

# Flutter / Dart (iOS client)
[*.dart]
indent_size = 2

# Markup / config
[*.{yml,yaml,xml,html}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
